{
  "name": "html-puzzle",
  "version": "0.1.0",
  "description": "HTML puzzle desktop app",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "pack": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "local.html-puzzle",
    "productName": "HTML Puzzle",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "script.js",
      "vendor/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
